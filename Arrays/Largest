#include <stdio.h>

int main()
{
    int a[100], n, i, max;//min

    printf("Enter size: ");
    scanf("%d", &n);

    for(i=0; i<n; i++)
        scanf("%d", &a[i]);

    max = a[0];//min=a[0]

    for(i=1; i<n; i++)
    {
        if(a[i] > max)  //a[i]<min
            max = a[i];  // min=a[i]
    }

    printf("Largest = %d", max);

    return 0;
}
